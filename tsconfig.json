{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": false,
    "strict": true,
    "declaration": true,
    "experimentalDecorators": true
  },
  "ts-node": {
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true,
    "esm": true
  },
  // fix ts-node/esm pathToFilURL error
  // "experimentalSpecifierResolution": "node",
  "transpileOnly": true,
  "esm": true,
  // end of fix
  "include": ["./src"],
  "exclude": ["**/*.spec.ts", "/src/seed/**/*", "/src/test/**/*"]
}
